PORT=3001
NODE_ENV=development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nti_db?schema=public"
REDIS_HOST=localhost
REDIS_PORT=6379
FRONTEND_URL=http://localhost:3000
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=files
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_REGION=auto
FILE_UPLOAD_PRESIGN_EXPIRES_SECONDS=900
FILE_UPLOAD_MAX_SIZE_BYTES=10485760
FILE_UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf
FILE_UPLOAD_VERIFY_OBJECT_ON_COMPLETE=false
# Optional for worker/containerized PDF rendering.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
PUPPETEER_HEADLESS=true
PUPPETEER_TIMEOUT_MS=30000
PDF_JOB_WAIT_TIMEOUT_MS=60000
PDF_WORKER_CONCURRENCY=2
SMTP_HOST=gmail.com
SMTP_PORT=587
SMTP_USER=user
SMTP_PASSWORD=pass
SMTP_FROM=email@gmail.com
JWT_ACCESS_SECRET=your_access_secret_key
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_FORCE_PASSWORD_CHANGE_SECRET=your_force_password_change_secret_key
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION_DAYS=7d
ARGON2_TIME_COST=3
TOKEN_BYTE_LENGTH=32
EMAIL_VERIFICATION_EXPIRATION_HOURS=24
PASSWORD_RESET_EXPIRATION_MINUTES=30
SUPERADMIN_TEMP_PASSWORD=change_me_before_seed
FORCE_PASSWORD_CHANGE_TOKEN_EXPIRATION_MINUTES=15

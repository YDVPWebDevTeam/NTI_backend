// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  STUDENT
  ADMIN
  COMPANY_OWNER
  COMPANY_EMPLOYEE
  MENTOR
  EVALUATOR
  CONTENT_EDITOR
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
}

enum UploadStatus {
  PENDING
  UPLOADED
  FAILED
}

enum FileVisibility {
  PRIVATE
  PUBLIC
}

enum ProgramType {
  PROGRAM_A
  PROGRAM_B
}

enum CallStatus {
  DRAFT
  OPEN
  CLOSED
  ARCHIVED
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  FORMALLY_VERIFIED
  EVALUATING
  NEEDS_INFO
  APPROVED
  REJECTED
  ONBOARDING
  ACTIVE_PROJECT
  PAUSED
  COMPLETED
  ARCHIVED
}

model User {
  id                 String  @id @default(uuid())
  firstName          String
  lastName           String
  email              String  @unique
  passwordHash       String
  mustChangePassword Boolean @default(false)

  refreshTokens      RefreshToken[]
  passwordResetToken PasswordResetToken?

  role UserRole @default(STUDENT)

  status UserStatus @default(PENDING)

  isEmailConfirmed Boolean @default(false) @map("isConfirmed")

  confirmationToken EmailVerificationToken?

  isAdminConfirmed Boolean @default(false) @map("isAdminConfirmed")

  teams TeamMember[]

  leadOfTeams       Team[]             @relation("TeamLead")
  systemInvitesSent SystemInvitation[] @relation("SystemInvitationInvitedBy")

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  uploads UploadedFile[]

  applicationsCreated Application[] @relation("ApplicationCreatedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([role, status])
  @@index([status, createdAt])
}

model UploadedFile {
  id String @id @default(uuid())

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  key          String @unique
  originalName String
  mimeType     String
  size         Int

  purpose    String?
  entityType String?
  entityId   String?
  visibility FileVisibility @default(PRIVATE)

  status UploadStatus @default(PENDING)

  uploadUrlExpiresAt DateTime
  uploadedAt         DateTime?
  failedAt           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, status])
  @@index([status, uploadUrlExpiresAt])
  @@index([entityType, entityId])
}

model TeamMember {
  userId String
  teamId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([userId, teamId])
  @@index([teamId])
}

model Team {
  id   String @id @default(uuid())
  name String

  leaderId String
  leader   User   @relation("TeamLead", fields: [leaderId], references: [id])

  members TeamMember[]

  invitations  Invitation[]
  applications Application[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lockedAt   DateTime? // When a team is locked, it cannot be modified (e.g., members cannot be added or removed)
  archivedAt DateTime?

  @@index([leaderId])
  @@index([archivedAt])
}

model Call {
  id String @id @default(uuid())

  type     ProgramType
  title    String
  status   CallStatus  @default(DRAFT)
  opensAt  DateTime?
  closesAt DateTime?

  applications Application[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, status])
  @@index([status, opensAt, closesAt])
}

model Application {
  id String @id @default(uuid())

  callId String
  call   Call   @relation(fields: [callId], references: [id], onDelete: Cascade)

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("ApplicationCreatedBy", fields: [createdById], references: [id])

  status      ApplicationStatus @default(DRAFT)
  submittedAt DateTime?
  decidedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([callId, status])
  @@index([teamId, status])
  @@index([createdById, status])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum SystemInvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model Invitation {
  id    String @id @default(uuid())
  email String

  token String @unique

  status InvitationStatus @default(PENDING)

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?

  @@index([teamId, status, expiresAt])
  @@index([email])
}

model EmailVerificationToken {
  id    String @id @default(uuid())
  token String @unique

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  acceptedAt DateTime?

  @@index([expiresAt])
}

model RefreshToken {
  id        String @id @default(uuid())
  tokenHash String @unique

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?

  @@index([userId, revokedAt, expiresAt])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String @id @default(uuid())
  tokenHash String @unique

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

enum OrganizationStatus {
  PENDING
  ACTIVE
  REJECTED
  SUSPENDED
}

model Organization {
  id          String             @id @default(uuid())
  name        String
  ico         String             @unique
  sector      String?
  description String?
  website     String?
  logoUrl     String?
  status      OrganizationStatus @default(PENDING)
  users       User[]
  invitations OrgInvitation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model OrgInvitation {
  id    String @id @default(uuid())
  email String
  token String @unique

  roleToAssign UserRole
  status       InvitationStatus @default(PENDING)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  revokedById    String?

  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  acceptedAt DateTime?
  updatedAt  DateTime  @updatedAt
  revokedAt  DateTime?

  @@index([organizationId, status, expiresAt])
  @@index([email, status, expiresAt])
  @@index([expiresAt])
}

model SystemInvitation {
  id    String @id @default(uuid())
  email String
  token String @unique

  roleToAssign UserRole
  status       SystemInvitationStatus @default(PENDING)

  invitedById String
  invitedBy   User   @relation("SystemInvitationInvitedBy", fields: [invitedById], references: [id])

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  expiresAt  DateTime
  acceptedAt DateTime?
  revokedAt  DateTime?

  @@index([status, expiresAt, email])
  @@index([email, roleToAssign, status, expiresAt])
}
